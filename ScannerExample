import java.util.*; //Import many things (include Scanner)

public class ScannerExample {
	public static void main(String[] args) {
		Scanner scan = new Scanner(System.in); // Makes a scanner which takes input
		int favoriteInt; // Makes an int called favoriteInt
		double favoriteDouble; // Makes a double called favoriteDouble
		System.out.print("Please give me your favorite intenger: "); // Lets the user know we are asking for an integer
		favoriteInt = scan.nextInt(); // Sets the variable, favoriteInt to whatever the user types on the keyboard
		System.out.print("Please give me your favorite decimal number: "); // Lets the user know we are asking for a double
		favoriteDouble = scan.nextDouble(); // Sets the variable, favoriteInt to whatever the user types on the keyboard
		System.out.println("Your favorite integer is a " + favoriteInt + " and your favorite decimal number is " + favoriteDouble);
	}
}
